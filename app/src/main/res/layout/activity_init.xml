<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/window_bg"
    tools:context=".init.InitActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BLUFI-NET"
                        android:textColor="@color/colorPrimary"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peer-to-Peer Mesh Network"
                        android:textColor="#64748B"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Mesh Node Count Badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/rounded_button"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/peerCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="peers"
                        android:textColor="#FFFFFFBB"
                        android:textSize="10sp"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- CARD 0: HOW TO USE GUIDE              -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="HOW TO USE"
                        android:textColor="@color/colorPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/guideToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▼ Show"
                        android:textColor="@color/colorPrimary"
                        android:textSize="12sp"
                        android:padding="4dp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/guideContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Step 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:background="#F0F9FF"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/rounded_button"
                            android:text="1"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Join the Mesh"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap 'Start Mesh Service'. Stay within 15–20 metres of another person running the app. The mesh forms automatically — no WiFi or internet needed."
                                android:textColor="#475569"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Step 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:background="#F0FDF4"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/rounded_button"
                            android:text="2"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Share Your Internet (Optional)"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="If you have mobile data or WiFi, enable 'Allow hosting server role' before starting. Your device becomes an internet gateway for the entire mesh. Others' requests are routed through you."
                                android:textColor="#475569"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Step 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:background="#FFFBEB"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/rounded_button"
                            android:text="3"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Browse the Web via Mesh"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Use the Mesh Web Browser below to load web pages. Your request travels over Bluetooth hops until it reaches a node with internet, which fetches and returns the page."
                                android:textColor="#475569"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Step 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:background="#FDF4FF"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/rounded_button"
                            android:text="4"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="System-wide Internet via VPN"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap 'Start Mesh VPN'. Grant the VPN permission. ALL your phone's traffic (every app — Chrome, WhatsApp, etc.) will tunnel through the mesh to the nearest internet-connected node."
                                android:textColor="#475569"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Step 5 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#FFF1F2"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/rounded_button"
                            android:text="5"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Send Email Over Mesh"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Use the Email card below. Fill To, Subject, Body and hit Send. Even if you have no internet, the email is routed over BLE hops to a gateway node that sends it for you."
                                android:textColor="#475569"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- CARD 1: DEVICE STATUS                 -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEVICE STATUS"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/myId"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ID: --"
                        android:textColor="#334155"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/whoAmi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_button"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="Offline"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Allow hosting server role"
                            android:textColor="#475569"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enable if you have mobile data / WiFi to share"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/canIBeServerSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- CARD 2: MESH CONTROL                  -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MESH CONTROL"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/startServices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_button"
                    android:text="Start Mesh Service"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Once started, your device joins the mesh and auto-discovers nearby peers via Bluetooth."
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginBottom="12dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/startVpn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_button"
                    android:text="🔒  Start Mesh VPN (System-wide Internet)"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Routes ALL your phone's internet traffic (every app) through the mesh to the nearest internet-connected node. Requires mesh to be running."
                    android:textColor="#94A3B8"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- CARD 3: MESH WEB BROWSER              -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌐  MESH WEB BROWSER"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Browse the web even without internet — your request travels over BLE hops to reach a gateway."
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F1F5F9"
                    android:padding="4dp">

                    <EditText
                        android:id="@+id/browserUrl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Enter URL (e.g. https://httpbin.org/get)"
                        android:inputType="textUri"
                        android:textColor="#334155"
                        android:textSize="14sp"
                        android:padding="10dp"
                        android:background="@android:color/transparent"
                        android:layout_marginEnd="8dp"
                        android:imeOptions="actionGo"
                        android:singleLine="true" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/browserGo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/rounded_button"
                        android:text="Go"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:paddingHorizontal="20dp" />

                </LinearLayout>

                <android.webkit.WebView
                    android:id="@+id/browserWebview"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="12dp"
                    android:background="#F8FAFC" />

            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- CARD 4: SEND EMAIL                    -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✉️  SEND EMAIL VIA MESH"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No internet? Your email travels over BLE hops to a gateway node that sends it for you."
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp" />

                <!-- To Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/emailTo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="recipient@example.com"
                    android:inputType="textEmailAddress"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="#F1F5F9"
                    android:layout_marginBottom="10dp"
                    android:singleLine="true" />

                <!-- Subject Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subject"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/emailSubject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Subject"
                    android:inputType="text"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="#F1F5F9"
                    android:layout_marginBottom="10dp"
                    android:singleLine="true" />

                <!-- Body Field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/emailBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Write your message here..."
                    android:inputType="textMultiLine"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="#F1F5F9"
                    android:layout_marginBottom="12dp"
                    android:minLines="4"
                    android:gravity="top" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/sendMail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_button"
                    android:text="Send Email via Mesh"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- CARD 5: HTTP REQUEST / SHARE          -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📤  HTTP REQUEST / SHARE TEXT"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enter a URL for HTTP GET, or any text to share/tweet via the mesh gateway."
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/httpInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="https://api.example.com/data  OR  any text to share"
                    android:inputType="text"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="#F1F5F9"
                    android:layout_marginBottom="12dp"
                    android:singleLine="true" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/tweetSomething"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_button"
                    android:text="Send via Mesh"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- CARD 6: DIAGNOSTICS                   -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖥  DIAGNOSTICS &amp; LOGS"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/debugger"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0F172A"
                    android:padding="12dp"
                    android:textColor="#38BDF8"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:minHeight="120dp"
                    android:maxLines="15"
                    android:scrollbars="vertical"
                    android:text="System logs will appear here..." />

            </LinearLayout>

            <!-- ══════════════════════════════════════ -->
            <!-- CARD 7: DISCOVERED PEERS              -->
            <!-- ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡  DISCOVERED PEERS"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recy_scan_results"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@android:layout/simple_list_item_2" />

                <TextView
                    android:id="@+id/noPeersHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No peers discovered yet. Start the mesh service and stay within 20m of others running BLUFI-NET."
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:padding="16dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>